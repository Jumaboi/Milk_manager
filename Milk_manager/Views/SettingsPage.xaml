<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Milk_manager.Views.SettingsPage"
             Title="Настройки"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <VerticalStackLayout Padding="16" Spacing="12">
        <Border StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}" Padding="12">
            <Label Text="⚙️ Настройки" Style="{StaticResource Headline}" />
        </Border>

        <Label Text="Опции приложения и тема" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray200}}" />
        <Border Padding="10" StrokeShape="RoundRectangle 10" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
            <VerticalStackLayout Spacing="6">
                <Label Text="Лог разработчика" FontAttributes="Bold" />
                <Label x:Name="DeveloperLogPathLabel" FontSize="12" LineBreakMode="CharacterWrap" />
                <Button Text="Показать путь к логу" Clicked="OnShowDeveloperLogPathClicked" />
            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentPage>
