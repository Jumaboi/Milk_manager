<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Milk_manager.Views.WriteOffPage"
             Title="Списание"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <VerticalStackLayout Padding="16" Spacing="12">
        <Border StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}" Padding="12">
            <Label Text="⚠️ Списание молока" Style="{StaticResource Headline}" />
        </Border>

        <Entry x:Name="LitersEntry" Placeholder="Литры" Keyboard="Numeric" />
        <Entry x:Name="ReasonEntry" Placeholder="Причина списания" />
        <Button Text="Создать списание" Clicked="OnCreateWriteOffClicked" />

        <Label Text="Все списания" FontAttributes="Bold" />
        <CollectionView x:Name="WriteOffsCollection" HeightRequest="420">
            <CollectionView.EmptyView>
                <Label Text="Списаний пока нет" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray200}}" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,6" Padding="8" StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8">
                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding Date, StringFormat='{0:g}'}" FontAttributes="Bold" />
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Liters, StringFormat='{0:F1} л'}" FontAttributes="Bold" />
                            <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding ReasonDisplay}" FontSize="12" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
