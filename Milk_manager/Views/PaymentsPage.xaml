<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Milk_manager.Views.PaymentsPage"
             Title="Выплаты"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <VerticalStackLayout Padding="16" Spacing="12">
        <Border StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}" Padding="12">
            <Label Text="💰 Выплаты" Style="{StaticResource Headline}" />
        </Border>

        <Picker x:Name="ClientPicker" Title="Клиент" ItemDisplayBinding="{Binding FullName}" />
        <Entry x:Name="AmountEntry" Placeholder="Сумма выплаты" Keyboard="Numeric" />
        <Entry x:Name="CommentEntry" Placeholder="Комментарий" />
        <Button Text="Создать выплату" Clicked="OnCreatePaymentClicked" />
    </VerticalStackLayout>
</ContentPage>
