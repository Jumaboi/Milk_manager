<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Milk_manager.Views.PurchasePage"
             Title="Прием молока"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <VerticalStackLayout Padding="16" Spacing="12">
        <Border StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}" Padding="12">
            <Label Text="🥛 Прием молока" Style="{StaticResource Headline}" />
        </Border>

        <Picker Title="Посёлок" ItemsSource="{Binding Villages}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedVillage}" />
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Picker Grid.Column="0" Title="Клиент" ItemsSource="{Binding Clients}" ItemDisplayBinding="{Binding FullName}" SelectedItem="{Binding SelectedClient}" />
            <Button Grid.Column="1" Text="+ Клиент" Command="{Binding AddClientCommand}" />
        </Grid>
        <Entry Placeholder="Литры" Text="{Binding Liters}" Keyboard="Numeric" />
        <Entry Placeholder="Цена за литр" Text="{Binding Price}" Keyboard="Numeric" />
        <Button Text="Сохранить приём" Command="{Binding SavePurchaseCommand}" />
    </VerticalStackLayout>
</ContentPage>
