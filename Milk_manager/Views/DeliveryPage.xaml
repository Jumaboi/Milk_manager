<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Milk_manager.Views.DeliveryPage"
             Title="Сдача на завод"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Border StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}" Padding="12">
                <Label Text="🚚 Сдача на завод" Style="{StaticResource Headline}" />
            </Border>

            <Label Text="Кликните по заводу или введите новый" FontAttributes="Bold" />
            <CollectionView x:Name="FactoriesCollection"
                            SelectionMode="Single"
                            SelectionChanged="OnFactorySelectionChanged"
                            HeightRequest="260">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10" StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                            <Grid RowDefinitions="Auto,Auto,Auto">
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Grid.Row="1" Text="{Binding Phone, StringFormat='Телефон: {0}'}" FontSize="12" />
                                <Label Grid.Row="2" Text="Выберите, затем укажите литры/цену" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray200}}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Entry x:Name="FactoryNameEntry" Placeholder="Название завода" />
            <Entry x:Name="LitersEntry" Placeholder="Литры" Keyboard="Numeric" TextChanged="OnAmountTextChanged" />
            <Entry x:Name="PriceEntry" Placeholder="Цена за литр" Keyboard="Numeric" TextChanged="OnAmountTextChanged" />
            <Label x:Name="TotalLabel" Text="Общая сумма: 0,00" FontAttributes="Bold" />
            <Button Text="Создать сдачу" Clicked="OnCreateDeliveryClicked" />

            <Label Text="Сдано сегодня" FontAttributes="Bold" />
            <CollectionView x:Name="DeliveriesCollection" HeightRequest="150">
                <CollectionView.EmptyView>
                    <Label Text="Пока нет сдач" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray200}}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,6" Padding="8" StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8">
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding FactoryName}" FontAttributes="Bold" />
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding TotalSum, StringFormat='{0:F2}'}" FontAttributes="Bold" />
                                <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Liters, StringFormat='Литры: {0:F1}'}" FontSize="12" />
                                <Label Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding PricePerLiter, StringFormat='Цена за литр: {0:F2}'}" FontSize="12" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
