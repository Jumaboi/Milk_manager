<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Milk_manager.Views.DeliveryPage"
             Title="Сдача на завод"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <VerticalStackLayout Padding="16" Spacing="12">
        <Border StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}" Padding="12">
            <Label Text="🚚 Сдача на завод" Style="{StaticResource Headline}" />
        </Border>

        <Entry x:Name="FactoryNameEntry" Placeholder="Название завода" />
        <Entry x:Name="LitersEntry" Placeholder="Литры" Keyboard="Numeric" />
        <Entry x:Name="PriceEntry" Placeholder="Цена за литр" Keyboard="Numeric" />
        <Button Text="Создать сдачу" Clicked="OnCreateDeliveryClicked" />
    </VerticalStackLayout>
</ContentPage>
