<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Milk_manager.Views.ClientsPage"
             Title="Клиенты"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <VerticalStackLayout Padding="16" Spacing="12">
        <Border StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}" Padding="12">
            <Label Text="👥 Клиенты" Style="{StaticResource Headline}" />
        </Border>

        <CollectionView ItemsSource="{Binding Clients}"
                        SelectedItem="{Binding SelectedClient, Mode=TwoWay}"
                        SelectionMode="Single"
                        HeightRequest="380">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10" StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                        <VerticalStackLayout>
                            <Label Text="{Binding FullName}" FontAttributes="Bold" />
                            <Label Text="{Binding Phone}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray200}}" />
                            <Label Text="{Binding DefaultPrice, StringFormat='Цена: {0:F2}'}" FontSize="12" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
            <Button Grid.Row="0" Grid.Column="0" Text="Добавить" Command="{Binding AddCommand}" />
            <Button Grid.Row="0" Grid.Column="1" Text="Изменить" Command="{Binding EditCommand}" />
            <Button Grid.Row="1" Grid.Column="0" Text="Позвонить" Command="{Binding CallCommand}" />
            <Button Grid.Row="1" Grid.Column="1" Text="Удалить" Command="{Binding DeleteCommand}" BackgroundColor="{StaticResource Magenta}" TextColor="{StaticResource White}" />
            <Button Grid.Row="2" Grid.ColumnSpan="2" Text="Обновить" Command="{Binding LoadCommand}" />
        </Grid>
    </VerticalStackLayout>
</ContentPage>
